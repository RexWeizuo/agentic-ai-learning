{
  "groups": [
    {
      "name": "前缀 fore-/forth- (向前/在前)",
      "words": [
        "fore",
        "forecast",
        "forehead",
        "foremost",
        "foresee",
        "forth",
        "forthcoming",
        "forward"
      ],
      "type": "词根",
      "note": "fore- 表示“前面、预先”，forth 表示“向前、向外”，注意 foresee 和 forecast 的近义关系。"
    },
    {
      "name": "词根 form-/fram- (形状/结构)",
      "words": [
        "formal",
        "format",
        "formation",
        "formula",
        "formulate",
        "frame",
        "framework"
      ],
      "type": "词根",
      "note": "源自拉丁语 forma（形状），frame 和 framework 侧重于物理或抽象的“框架、结构”。"
    },
    {
      "name": "词根 fract-/frag- (破碎)",
      "words": [
        "fraction",
        "fracture",
        "fragile",
        "fragment"
      ],
      "type": "词根",
      "note": "fract 和 frag 同源，表示“打破、破碎”。fraction 是分数/小部分，fragile 是易碎的。"
    },
    {
      "name": "词根 flu-/fluct- (流动)",
      "words": [
        "fluent",
        "fluid",
        "flush",
        "fluctuate"
      ],
      "type": "词根",
      "note": "flu- 表示“流动”，fluent 指语言流利，fluid 指流体，fluctuate 指像波浪一样起伏波动。"
    },
    {
      "name": "词根 gen- (产生/种类/基因)",
      "words": [
        "gene",
        "generate",
        "generator",
        "genetic",
        "genius",
        "gender",
        "generalise"
      ],
      "type": "词根",
      "note": "gen- 表示“出生、产生、种类”。gene/genetic 与基因相关，generate 是产生，genius 原指守护神/天赋。"
    },
    {
      "name": "词根 graph-/gram- (写/画/重量)",
      "words": [
        "gram",
        "grammar",
        "graph",
        "graphic"
      ],
      "type": "词根",
      "note": "gram/graph 表示“写、画、记录”。graph 是图表，graphic 是生动的/图形的，grammar 是语法规则。"
    },
    {
      "name": "合成词/词根 hand- (手)",
      "words": [
        "handbook",
        "handful",
        "handicap",
        "handle",
        "handwriting"
      ],
      "type": "词族",
      "note": "hand- 构成的合成词。handicap 原指手里拿着帽子乞讨，后引申为“障碍、不利条件”。"
    },
    {
      "name": "词族 hard- (硬/困难)",
      "words": [
        "harden",
        "hardly",
        "hardship",
        "hardware"
      ],
      "type": "词族",
      "note": "hard 的派生词。注意 hardly 意思是“几乎不”，而 hardship 是“艰难、困苦”，hardware 是“硬件”。"
    },
    {
      "name": "近义词 (巨大/宏大)",
      "words": [
        "giant",
        "gigantic",
        "grand",
        "great"
      ],
      "type": "近义",
      "note": "都表示“大”。giant/gigantic 侧重体型或规模巨大，grand 侧重宏伟、庄重，great 侧重伟大、重要。"
    },
    {
      "name": "主题/近义 (发光与视觉)",
      "words": [
        "flare",
        "glare",
        "glitter",
        "glow",
        "glimpse"
      ],
      "type": "近义",
      "note": "与光和视觉相关。flare 是闪耀/爆发，glare 是刺眼的光，glitter 是闪烁，glow 是红光/发热，glimpse 是一瞥。"
    },
    {
      "name": "主题 (法律与犯罪)",
      "words": [
        "fraud",
        "gaol",
        "guilt",
        "guilty"
      ],
      "type": "主题",
      "note": "法律场景核心词。fraud 是欺诈，gaol 是监狱（英式拼写，同 jail），guilt/guilty 是罪行/有罪的。"
    },
    {
      "name": "近义词 (群/帮/集合)",
      "words": [
        "flock",
        "herd",
        "gang",
        "galaxy"
      ],
      "type": "近义",
      "note": "表示“群”。flock 多指羊群/鸟群，herd 指牛/象等兽群，gang 指一帮人，galaxy 指星系或一群显赫人物。"
    },
    {
      "name": "词族/近义 (问候/打招呼)",
      "words": [
        "greet",
        "greeting",
        "hail",
        "hello"
      ],
      "type": "词族",
      "note": "greet 是动词问候，greeting 是名词。hail 除了冰雹，也有“欢呼、打招呼”之意。"
    },
